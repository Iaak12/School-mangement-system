# ============================
# School ERP — Backend .env
# ============================

NODE_ENV=development
PORT=5000

# MongoDB
MONGO_URI=mongodb://localhost:27017/school_erp

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_in_production_min_32_chars
JWT_REFRESH_EXPIRES_IN=7d

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Nodemailer (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_school_email@gmail.com
SMTP_PASS=your_app_password
FROM_EMAIL=noreply@yourschool.com
FROM_NAME=School ERP

# School Info (used in emails/PDFs)
SCHOOL_NAME=Springfield Public School
SCHOOL_ADDRESS=123 Education Street, City, State - 000000
SCHOOL_PHONE=+91-9999999999
SCHOOL_EMAIL=info@springfield.edu
SCHOOL_WEBSITE=https://www.springfield.edu

# Frontend URL (for CORS & reset password links)
FRONTEND_URL=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
